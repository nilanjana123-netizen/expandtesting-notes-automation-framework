pipeline {

    agent any

    tools {
        maven 'Maven'
        jdk   'JDK21'
    }

    stages {

        stage('Build and Test') {
            steps {
                dir('Notes_15') {
                    bat 'mvn clean test'
                }
            }
        }

        stage('Run JMeter Test') {
            steps {
                dir('Notes_15') {
                    bat '''
                    jmeter -n -t performance/jmeter/testplans/testplan.jmx ^
                    -l performance/jmeter/results/results.jtl ^
                    -j performance/jmeter/results/jmeter.log
                    '''
                }
            }
        }

        stage('Generate JMeter HTML Report') {
            steps {
                dir('Notes_15') {
                    bat '''
                    if exist performance\\jmeter\\results\\html-report (
                        rmdir /s /q performance\\jmeter\\results\\html-report
                    )
                    jmeter -g performance/jmeter/results/results.jtl ^
                    -o performance/jmeter/results/html-report
                    '''
                }
            }
        }
    }

    post {

        always {

            allure([
                includeProperties: false,
                jdk: 'JDK21',
                results: [[path: 'Notes_15/allure-results']]
            ])

            publishHTML([
                allowMissing:          true,
                alwaysLinkToLastBuild: true,
                keepAll:               true,
                reportDir:             'Notes_15/performance/jmeter/results/html-report',
                reportFiles:           'index.html',
                reportName:            'JMeter HTML Report'
            ])

            junit(
                testResults:          'Notes_15/target/surefire-reports/**/*.xml',
                allowEmptyResults:    true
            )

            archiveArtifacts(
                artifacts:        'Notes_15/screenshots/*.png',
                allowEmptyArchive: true
            )

            archiveArtifacts(
                artifacts:        'Notes_15/performance/jmeter/results/**/*',
                allowEmptyArchive: true
            )
        }
    }
}
