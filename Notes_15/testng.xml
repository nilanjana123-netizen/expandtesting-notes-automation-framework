<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Notes Automation Suite"
       parallel="tests"
       thread-count="3">

    <listeners>

        <listener
                class-name="org.example.framework.listeners.TestListener"/>

    </listeners>

    <!-- UI Tests -->

    <test name="UI Tests">

        <classes>

            <class
                    name="org.example.framework.tests.ui.LoginTest"/>

            <class
                    name="org.example.framework.tests.ui.CreateNoteTest"/>

            <class
                    name="org.example.framework.tests.ui.EditNoteTest"/>

            <class
                    name="org.example.framework.tests.ui.DeleteNoteTest"/>

        </classes>

    </test>

    <!-- API Tests -->

    <test name="API Tests">

        <classes>

            <class
                    name="org.example.framework.tests.api.CreateNoteApiTest"/>

            <class
                    name="org.example.framework.tests.api.FetchNoteApiTest"/>

            <class
                    name="org.example.framework.tests.api.DeleteNoteApiTest"/>

        </classes>

    </test>

    <!-- Hybrid Tests -->

    <test name="Hybrid Tests">

        <classes>

            <class
                    name="org.example.framework.tests.e2e.HybridTest"/>

        </classes>

    </test>

</suite>